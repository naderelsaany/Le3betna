{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "stats": {
          ".read": "auth != null"
        }
      }
    },
    "rooms": {
      "$roomCode": {
        ".write": "auth != null && (!data.exists() || data.child('hostUid').val() === auth.uid)",
        "status": { ".read": "auth != null" },
        "hostUid": { ".read": "auth != null" },
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "gameState": {
          ".read": "auth != null && (root.child('rooms').child($roomCode).child('hostUid').val() === auth.uid || root.child('rooms').child($roomCode).child('players').child(auth.uid).exists())",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('hostUid').val() === auth.uid"
        },
        "hands": {
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('rooms').child($roomCode).child('hostUid').val() === auth.uid)",
            ".write": "auth != null && root.child('rooms').child($roomCode).child('hostUid').val() === auth.uid"
          }
        },
        "moves": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('hostUid').val() === auth.uid",
          "$moveId": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['uid', 'timestamp']) && newData.child('uid').val() === auth.uid"
          }
        },
        "transient": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
